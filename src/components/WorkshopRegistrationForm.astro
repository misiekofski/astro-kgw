---
import { KGW_DATA, WORKSHOP_CONFIG } from '../consts';

interface Props {
	workshopType: keyof typeof WORKSHOP_CONFIG;
}

const { workshopType } = Astro.props;
const workshop = WORKSHOP_CONFIG[workshopType];
---

<div class="workshop-registration">
	<div class="workshop-header">
		<h2>{workshop.title}</h2>
		<p class="workshop-description">{workshop.description}</p>
		<div class="workshop-info">
			<span class="info-badge">💰 Koszt: {workshop.price} zł</span>
			<span class="info-badge">👥 Limit miejsc: {workshop.maxParticipants} osób</span>
		</div>
	</div>

	<div class="payment-info-box">
		<h3>💳 Informacje o płatności</h3>
		<p>Opłata za warsztaty: <strong>{workshop.price} zł</strong></p>
		<p>Numer konta KGW:</p>
		<p class="bank-account">{KGW_DATA.bankAccount}</p>
		<p class="payment-note">
			Tytuł przelewu: <strong>Warsztaty świec - [Twoje Imię i Nazwisko]</strong>
		</p>
	</div>

	{workshop.googleFormUrl ? (
		<div class="google-form-container">
			<iframe 
				src={workshop.googleFormUrl}
				width="100%" 
				height="1400" 
				frameborder="0" 
				marginheight="0" 
				marginwidth="0"
				title="Formularz rejestracyjny na warsztaty"
			>
				Ładowanie formularza...
			</iframe>
		</div>
	) : (
		<div class="no-form-warning">
			<p>⚠️ Formularz nie jest jeszcze skonfigurowany. Skontaktuj się z nami:</p>
			<p><a href="mailto:{KGW_DATA.email}">{KGW_DATA.email}</a></p>
		</div>
	)}
</div>


<style>
	.workshop-registration {
		max-width: 700px;
		margin: 0 auto;
	}

	.workshop-header {
		text-align: center;
		margin-bottom: 2rem;
		padding: 1.5rem;
		background: linear-gradient(135deg, var(--kgw-cream) 0%, #fff 100%);
		border-radius: 12px;
		border: 2px solid var(--kgw-orange);
	}

	.workshop-header h2 {
		color: var(--kgw-green-dark);
		margin-bottom: 0.5rem;
	}

	.workshop-description {
		font-size: 1.1rem;
		color: rgb(var(--gray-dark));
		margin-bottom: 1rem;
	}

	.workshop-info {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	.info-badge {
		display: inline-block;
		padding: 0.5rem 1rem;
		background: var(--kgw-green);
		color: white;
		border-radius: 20px;
		font-weight: bold;
		font-size: 0.95rem;
	}

	.payment-info-box {
		background: rgb(var(--gray-light));
		padding: 1.5rem;
		border-radius: 8px;
		margin-bottom: 2rem;
		border-left: 4px solid var(--kgw-orange);
	}

	.payment-info-box h3 {
		color: var(--kgw-green-dark);
		margin-bottom: 1rem;
		font-size: 1.1rem;
	}

	.payment-info-box p {
		margin: 0.5rem 0;
	}

	.google-form-container {
		background: white;
		padding: 1rem;
		border-radius: 12px;
		box-shadow: 0 2px 8px rgba(0,0,0,0.1);
		overflow: hidden;
	}

	.google-form-container iframe {
		display: block;
		width: 100%;
		border: none;
	}

	.no-form-warning {
		background: #fff3cd;
		color: #856404;
		padding: 2rem;
		border-radius: 8px;
		border: 1px solid #ffeeba;
		text-align: center;
	}

	.no-form-warning a {
		color: var(--kgw-green-dark);
		font-weight: bold;
	}

	.bank-account {
		font-family: 'Courier New', monospace;
		font-size: 1.1rem;
		font-weight: bold;
		color: var(--kgw-green-dark);
		background: white;
		padding: 0.5rem;
		border-radius: 4px;
		display: inline-block;
	}

	.payment-note {
		font-style: italic;
		color: rgb(var(--gray-dark));
		margin-top: 1rem;
	}

	@media (max-width: 720px) {
		.workshop-info {
			flex-direction: column;
			align-items: center;
		}

		.google-form-container {
			padding: 0.5rem;
		}

		.google-form-container iframe {
			height: 1600px;
		}
	}
</style>

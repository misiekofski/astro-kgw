---
import { WORKSHOP_CONFIG } from '../consts';

interface Props {
	workshopType: keyof typeof WORKSHOP_CONFIG;
}

const { workshopType } = Astro.props;
const workshop = WORKSHOP_CONFIG[workshopType];

// Pobieranie danych z Google Sheets API
// Dla Cloudflare Workers używamy runtime.env
const runtime = Astro.locals.runtime;
const API_KEY = runtime?.env?.PUBLIC_GOOGLE_SHEETS_API_KEY || import.meta.env.PUBLIC_GOOGLE_SHEETS_API_KEY;
const SHEET_ID = workshop.googleSheetsId;
const RANGE = workshop.sheetsRange;

// Debug - usuń po sprawdzeniu
console.log('Runtime available:', !!runtime);
console.log('API_KEY exists:', !!API_KEY);
console.log('API_KEY source:', runtime?.env?.PUBLIC_GOOGLE_SHEETS_API_KEY ? 'runtime.env' : 'import.meta.env');
console.log('SHEET_ID:', SHEET_ID);
console.log('RANGE:', RANGE);

let participants = [];
let fetchError = null;

if (SHEET_ID && RANGE && API_KEY) {
	try {
		const url = `https://sheets.googleapis.com/v4/spreadsheets/${SHEET_ID}/values/${RANGE}?key=${API_KEY}`;
		const response = await fetch(url);
		
		if (!response.ok) {
			throw new Error(`HTTP error! status: ${response.status}`);
		}
		
		const data = await response.json();
		
		if (data.values && data.values.length > 0) {
			participants = data.values.map((row) => ({
				registeredAt: row[0] || '',
				firstName: row[1] || '',
				lastName: row[2] || '',
				email: row[3] || '',
				phone: row[4] || '',
				paymentConsent: row[5] || ''
			}));
		}
	} catch (error) {
		console.error('Błąd pobierania danych z Google Sheets:', error);
		fetchError = error.message;
	}
} else if (!API_KEY) {
	fetchError = 'Brak klucza API - skonfiguruj PUBLIC_GOOGLE_SHEETS_API_KEY w zmiennych środowiskowych';
} else if (!SHEET_ID) {
	fetchError = 'Brak ID arkusza Google Sheets w konfiguracji';
} else if (!RANGE) {
	fetchError = 'Brak zakresu danych (sheetsRange) w konfiguracji';
}

const spotsLeft = workshop.maxParticipants - participants.length;
---

<div class="participants-section">
	<div class="participants-header">
		<h3>📋 Lista zapisanych uczestników</h3>
		<div class="spots-info">
			<span class="spots-badge" class:list={[spotsLeft <= 5 && 'low']}>
				{spotsLeft > 0 
					? `Wolne miejsca: ${spotsLeft} / ${workshop.maxParticipants}`
					: 'Brak wolnych miejsc'
				}
			</span>
		</div>
	</div>

	{fetchError ? (
		<div class="error-message">
			<p>⚠️ Nie można pobrać listy uczestników.</p>
			<p class="error-details">{fetchError}</p>
			<p class="error-hint">Sprawdź konfigurację Google Sheets API w pliku .env</p>
		</div>
	) : participants.length > 0 ? (
		<div class="participants-list">
			<table class="participants-table">
				<thead>
					<tr>
						<th>Lp.</th>
						<th>Imię i nazwisko</th>
						<th>Kontakt</th>
						<th>Data zapisu</th>
					</tr>
				</thead>
				<tbody>
					{participants.map((participant, index) => (
						<tr>
							<td>{index + 1}</td>
							<td>{participant.firstName} {participant.lastName}</td>
							<td>
								{participant.email && <div class="contact-item">📧 {participant.email}</div>}
								{participant.phone && <div class="contact-item">📱 {participant.phone}</div>}
							</td>
							<td>{new Date(participant.registeredAt).toLocaleDateString('pl-PL')}</td>
						</tr>
					))}
				</tbody>
			</table>
		</div>
	) : (
		<div class="no-participants">
			<p>🎯 Bądź pierwszą osobą, która zapisze się na warsztaty!</p>
		</div>
	)}

	<div class="info-note">
		<p>
			<strong>ℹ️ Informacja:</strong> Lista uczestników jest aktualizowana automatycznie 
			po zatwierdzeniu rejestracji i potwierdzeniu wpłaty.
		</p>
	</div>
</div>

<style>
	.participants-section {
		margin-top: 3rem;
		padding: 1.5rem;
		background: white;
		border-radius: 12px;
		box-shadow: 0 2px 8px rgba(0,0,0,0.1);
	}

	.participants-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 1.5rem;
		padding-bottom: 1rem;
		border-bottom: 3px solid var(--kgw-orange);
	}

	.participants-header h3 {
		color: var(--kgw-green-dark);
		margin: 0;
	}

	.spots-info {
		text-align: right;
	}

	.spots-badge {
		display: inline-block;
		padding: 0.5rem 1rem;
		background: var(--kgw-green);
		color: white;
		border-radius: 20px;
		font-weight: bold;
		font-size: 0.9rem;
	}

	.spots-badge.low {
		background: var(--kgw-orange);
		animation: pulse 2s infinite;
	}

	@keyframes pulse {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.7; }
	}

	.participants-list {
		overflow-x: auto;
	}

	.participants-table {
		width: 100%;
		border-collapse: collapse;
	}

	.participants-table th {
		background: rgb(var(--gray-light));
		color: var(--kgw-green-dark);
		padding: 0.75rem;
		text-align: left;
		font-weight: bold;
		border-bottom: 2px solid var(--kgw-green);
	}

	.participants-table td {
		padding: 0.75rem;
		border-bottom: 1px solid rgb(var(--gray-light));
	}

	.participants-table tbody tr:hover {
		background: rgb(var(--gray-light));
	}

	.contact-item {
		font-size: 0.9rem;
		color: rgb(var(--gray-dark));
		margin: 0.25rem 0;
	}

	.no-participants {
		text-align: center;
		padding: 3rem 1rem;
		color: rgb(var(--gray));
		font-style: italic;
	}

	.info-note {
		margin-top: 1.5rem;
		padding: 1rem;
		background: rgb(var(--gray-light));
		border-radius: 8px;
		border-left: 4px solid var(--kgw-green);
	}

	.info-note p {
		margin: 0;
		font-size: 0.9rem;
		color: rgb(var(--gray-dark));
	}

	.error-message {
		background: #fff3cd;
		color: #856404;
		padding: 2rem;
		border-radius: 8px;
		border: 1px solid #ffeeba;
		text-align: center;
	}

	.error-message p {
		margin: 0.5rem 0;
	}

	.error-details {
		font-family: monospace;
		font-size: 0.85rem;
		background: rgba(0,0,0,0.05);
		padding: 0.5rem;
		border-radius: 4px;
	}

	.error-hint {
		font-size: 0.9rem;
		font-style: italic;
		color: rgb(var(--gray-dark));
	}

	@media (max-width: 720px) {
		.participants-header {
			flex-direction: column;
			align-items: flex-start;
			gap: 1rem;
		}

		.participants-table {
			font-size: 0.85rem;
		}

		.participants-table th,
		.participants-table td {
			padding: 0.5rem;
		}
	}
</style>
